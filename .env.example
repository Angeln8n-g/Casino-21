# ==========================================
# CASINO 21 - ROOT ENVIRONMENT TEMPLATE (.env.example)
# ==========================================

# FRONTEND
VITE_SUPABASE_URL=http://localhost:3001
VITE_SUPABASE_ANON_KEY=TU_VITE_SUPABASE_ANON_KEY
VITE_SOCKET_URL=http://localhost:3001
VITE_SHOW_RULES_VERSION=false
VITE_VAPID_PUBLIC_KEY=TU_VAPID_PUBLIC_KEY

EXPO_PUBLIC_SUPABASE_URL=http://localhost:3001
EXPO_PUBLIC_SUPABASE_ANON_KEY=TU_VITE_SUPABASE_ANON_KEY
EXPO_PUBLIC_SOCKET_URL=http://localhost:3001
EXPO_PUBLIC_SHOW_RULES_VERSION=false

# BACKEND
NODE_ENV=production
PORT=4000
SUPABASE_URL=http://supabase-kong:8000
SUPABASE_SERVICE_ROLE_KEY=TU_SUPABASE_SERVICE_ROLE_KEY
JWT_SECRET=TU_JWT_SECRET
CORS_ORIGINS=*
ALLOW_INSECURE_JWT_FALLBACK=false
EXPOSE_RULES_VERSION=false
VAPID_PUBLIC_KEY=TU_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=TU_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:admin@example.com

# SUPABASE INFRASTRUCTURE
POSTGRES_PASSWORD=TU_POSTGRES_PASSWORD
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

ANON_KEY=TU_SUPABASE_ANON_KEY
SERVICE_ROLE_KEY=TU_SUPABASE_SERVICE_ROLE_KEY
JWT_EXPIRY=3600

DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=TU_POSTGRES_PASSWORD

SECRET_KEY_BASE=TU_SECRET_KEY_BASE_MIN_64_CHARS
REALTIME_DB_ENC_KEY=TU_REALTIME_DB_ENC_KEY_16_HEX
VAULT_ENC_KEY=TU_VAULT_ENC_KEY_32_HEX
PG_META_CRYPTO_KEY=TU_PG_META_CRYPTO_KEY

SUPABASE_PUBLIC_URL=http://localhost:8000
API_EXTERNAL_URL=http://localhost:8000/auth/v1
SITE_URL=http://localhost:3001

KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
STUDIO_PORT=8082
