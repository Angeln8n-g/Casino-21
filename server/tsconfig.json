{
  "compilerOptions": {
    "target": "es2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0"  // use valid value: "5.0" is not allowed; remove or set to "5.5" or "5.6"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
